[global]
# Display
monitor = 1
origin = top-right
offset = (15, 25)
width = (300, 300)
height = (100, 100)
gap_size = 5
notification_limit = 5
script = /data/data/com.termux/files/home/.local/bin/dunst-log.py

# Appearance
font = "Ioskeley Mono 11"
frame_width = 1
separator_color = frame
corner_radius = 0
corners = top-left,bottom
progress_bar_corner_radius = 0
progress_bar_corners = top-left,bottom-right

# Colors loaded from theme via dunstrc.d/00-colors.conf

# Timing
timeout = 5
idle_threshold = 120

# Icons
max_icon_size = 64
icon_path = /data/data/com.termux/files/usr/share/icons/Papirus-Dark/48x48/apps:/data/data/com.termux/files/usr/share/icons/Papirus-Dark/48x48/status:/usr/share/icons/hicolor/48x48/apps:/data/data/com.termux/files/home/.icons
enable_recursive_icon_lookup = true

# Behavior
dmenu = ~/.config/rofi/launch.sh
show_indicators = yes
sticky_history = yes
history_length = 20

# Mouse actions
mouse_left_click = close_current
mouse_right_click = close_all
mouse_middle_click = context_all

# Format
format = "<b>%a</b>\n%s\n<i>%b</i>"

[urgency_low]
timeout = 3
default_icon = "~/.config/dunst/icons/bell-badge-low.svg"

[urgency_normal]
timeout = 5
default_icon = "~/.config/dunst/icons/bell-badge.svg"

[urgency_critical]
timeout = 0
default_icon = "~/.config/dunst/icons/alert-decagram.svg"
